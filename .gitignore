# =========================================

# BARBOT CORE .gitignore

# =========================================

# -----------------------------------------

# Python

# -----------------------------------------

**pycache**/
*.py[cod]
*$py.class

*.so
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/

*.egg-info/
.installed.cfg
*.egg

# Virtual environments

.venv/
venv/
ENV/
env/

# Pytest

.pytest_cache/
.coverage
htmlcov/

# MyPy

.mypy_cache/

# Ruff

.ruff_cache/

# -----------------------------------------

# VS Code

# -----------------------------------------

.vscode/

# -----------------------------------------

# Node.js

# -----------------------------------------

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------

# PlatformIO

# -----------------------------------------

.pio/
.pioenvs/

# -----------------------------------------

# Environment / Secrets

# -----------------------------------------

.env
.env.*
!.env.example

# -----------------------------------------

# OS Generated Files

# -----------------------------------------

.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------

# Logs

# -----------------------------------------

*.log

# -----------------------------------------

# Temporary Files

# -----------------------------------------

tmp/
temp/
*.tmp

# -----------------------------------------

# Artifacts

# -----------------------------------------

artifacts/telemetry_logs/*
!artifacts/telemetry_logs/.gitkeep

artifacts/failed_imports/*
!artifacts/failed_imports/.gitkeep

# -----------------------------------------

# Jupyter

# -----------------------------------------

.ipynb_checkpoints/

# -----------------------------------------

# Coverage

# -----------------------------------------

coverage.xml

# -----------------------------------------

# Build Outputs

# -----------------------------------------

*.bin
*.hex
*.elf

# -----------------------------------------

# Local MCP / AI Runtime State

# -----------------------------------------

.kilocode/cache/
.kilocode/runtime/
.kilocode/temp/

# -----------------------------------------

# SQLite Databases

# -----------------------------------------

*.db
*.sqlite3

# -----------------------------------------

# Ignore Local Serial Dumps

# -----------------------------------------

serial_logs/
